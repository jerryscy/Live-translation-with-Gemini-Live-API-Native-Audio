.env
.env.*

# Docs (not needed in the runtime image)
*.md

# Python cache / build junk
__pycache__/
*.py[cod]
*.so

# OS / editor
.DS_Store
.vscode/
.idea/

# Archives / scratch
*.zip
*.wav
*.log
run.sh

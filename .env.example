# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values.
#     cp .env.example .env
# `.env` is git-ignored so your real settings won't be committed.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Google Cloud / Vertex AI configuration
# ---------------------------------------------------------------------------
# The GCP project and region used for the Gemini Live API (Vertex AI).
# Authenticate first with:  gcloud auth application-default login
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Gemini Live model with native audio.
LIVE_API_MODEL="gemini-live-2.5-flash-native-audio"

# ---------------------------------------------------------------------------
# Default translation direction (BCP-47 codes from the Chirp 3 HD language set)
# ---------------------------------------------------------------------------
# Default input  language: Mandarin Chinese (China)
DEFAULT_SOURCE_LANG="Mandarin Chinese (China)"
DEFAULT_SOURCE_LANG_CODE="cmn-CN"
# Default output language: English (United States)
DEFAULT_TARGET_LANG="English (United States)"
DEFAULT_TARGET_LANG_CODE="en-US"

# ---------------------------------------------------------------------------
# Session behavior
# ---------------------------------------------------------------------------
# On Stop, the Live API session is kept alive (paused) for instant resume.
# Close it after this many seconds of inactivity to avoid holding a billable
# session open. A new Start after this will reconnect.
IDLE_CLOSE_SECONDS="30"

# Verbose logging of raw Live API transcription timing (true/false).
DEBUG_LIVE_API="false"

# ---------------------------------------------------------------------------
# In-app Google OAuth login (optional)
# ---------------------------------------------------------------------------
# When both OAUTH_CLIENT_ID and OAUTH_CLIENT_SECRET are set, every page, the
# /config API and the /ws WebSocket require a signed-in Google user whose email
# domain matches ALLOWED_HD. Leave them blank to disable auth (open app).
#
# This .env is for LOCAL development only. In production (Cloud Run) keep
# OAUTH_CLIENT_SECRET and SESSION_SECRET in Secret Manager and inject them with
# `gcloud run deploy --set-secrets=...` (see DEPLOY.md) instead of plain env.
#
# Create a "Web application" OAuth client in Google Cloud Console
# (APIs & Services > Credentials) and register these Authorized redirect URIs:
#   local:      http://127.0.0.1:8000/auth
#   Cloud Run:  https://<your-service-url>/auth
OAUTH_CLIENT_ID=""
OAUTH_CLIENT_SECRET=""
# Callback URL that matches a registered redirect URI (scheme-exact).
OAUTH_REDIRECT_URI="http://127.0.0.1:8000/auth"
# Allowed Google Workspace domain (hosted domain).
ALLOWED_HD="google.com"
# Random, STABLE string used to sign the session cookie. Must be the same
# across restarts/instances. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=""
